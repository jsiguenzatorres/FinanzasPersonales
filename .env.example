# ============================================================================
# FlowFinance — Environment variables (example)
# Copy to .env.local for local dev, .env.production for VPS deploy.
# NEVER commit .env files with real values.
# ============================================================================

# --- Node / Next.js ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FlowFinance

# --- Supabase ---
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>     # ¡SOLO en server-side / Edge Functions!
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_DB_PASSWORD=<db-password>               # solo para CLI local

# --- Gemini (Google AI Studio) ---
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_LITE=gemini-2.5-flash-lite

# --- Stripe (modo test al inicio) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ELITE=price_xxx

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@flowfinance.app

# --- FX Rates (ExchangeRate-API free tier) ---
EXCHANGERATE_API_KEY=<your-key>

# --- Telemetría (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry ---
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=flowfinance
SENTRY_PROJECT=web
SENTRY_AUTH_TOKEN=sntrys_xxx

# --- VPS deploy (solo en GitHub Actions secrets) ---
# VPS_HOST=
# VPS_USER=
# VPS_SSH_KEY=
# VPS_PORT=22

# --- Belvo (Open Banking — Fase 2) ---
# BELVO_SECRET_ID=
# BELVO_SECRET_PASSWORD=
# BELVO_ENV=sandbox

# --- WhatsApp Business (Fase 3) ---
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
